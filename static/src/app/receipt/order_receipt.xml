<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Remove logo and tracking number counter from receipt header -->
    <t t-inherit="point_of_sale.ReceiptHeader" t-inherit-mode="extension">
        <xpath expr="//img[contains(@class,'pos-receipt-logo')]" position="replace"/>
        <xpath expr="//h1[contains(@class,'tracking-number')]" position="replace"/>
        <xpath expr="//div[contains(@class,'fw-bolder')]" position="replace"/>
    </t>

    <!-- Restructure QR code: smaller, right-aligned, text beside it -->
    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[@t-if='props.data.pos_qr_code']" position="replace">
            <div t-if="props.data.pos_qr_code" style="display:flex; flex-direction:row; align-items:center; justify-content:flex-end; gap:8px; margin-top:8px;">
                <div style="font-size:10px; text-align:right; flex:1;">
                    Scan de QR-code om een digitale factuur aan te vragen van uw aankoop:
                </div>
                <img id="posqrcode" t-att-src="props.data.pos_qr_code" style="width:33%; height:33%; flex-shrink:0;"/>
            </div>
        </xpath>
    </t>

    <!-- Remove spacing before ticket_code instructions and remove "Powered by Odoo" -->
    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//div[@t-if='props.data.ticket_code']" position="replace">
            <div t-if="props.data.ticket_code">
                <div class="pos-receipt-order-data">
                    You can go to <t t-out="props.data.base_url"/>/pos/ticket and use the code below to request an invoice online
                </div>
                <div class="pos-receipt-order-data">
                    Unique Code: <t t-out="props.data.ticket_code"/>
                </div>
            </div>
        </xpath>
        <xpath expr="//p[text()='Powered by Odoo']" position="replace"/>
    </t>

</templates>
